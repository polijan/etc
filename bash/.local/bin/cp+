#!/usr/bin/env bash

# Usage: $0 [...]
# interactive wrapper to cp
#
# * With a single (non -*) argument which is an existing filename:
#   1. Interactively prompt the destination (the prompt is initially populated
#      with the given filename prefixed with its modification date)
#   2. Call 'cp -i -a "$1" <destination>'
#
# * Otherwise, call 'cp -i'

CP() { cp -i "$@"; exit; }

{ [ -t 0 ] && [ -t 1 ]; } || CP "$@"
[ $# -eq 1 ] || CP "$@"
case $1 in -*)  CP "$@";; esac
[ -e "$1" ]  || CP "$@"

# Note: date(1) from GNU coreutils, busybox, or toybox all have the -r option to
#       get the modification date of a file, but let's use the current date in
#       case date doesn't support the -r option.
FMT='%Y-%m-%d_%H%M%S'
MTIME=$(date -r "$1" +"$FMT" 2>/dev/null) || MTIME=$(date +"$FMT")

color=$(printf '\033[34m')
reset=$(printf '\033[0m')
IFS= read -r -e -p "${color}copy to:${reset} " -i "$1.$MTIME" || exit
[ -z "$REPLY" ]     && exit 1
# [ "$REPLY" = "$1" ] && exit 1
CP -a "$1" "$REPLY"
