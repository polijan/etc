#!/bin/sh

# Usage: $0 [QUERY]
# preview my 'etc' directory

########################################################################
exists() { command -v "$@" > /dev/null; }
die()    { printf '%s\n' "$*" >&2; exit 1; }

# args: PACKAGE
# returns 0 if package is installed, non-zero otherwise
# assumes dpkg packaging system (Debian's derivatives and some others)
is_installed() {
   exists "$1" || dpkg -L "$1" >/dev/null 2>/dev/null
}
########################################################################

if [ -n "$ETC_HOME" ]; then
   cd "$ETC_HOME"
elif exists etc-home; then
   cd "$(etc-home)"
fi          || die "cannot find where 'etc' is located"

exists fzf  || die 'requires fzf(1)'

if exists lsd; then
   TREE='lsd --tree -ahF --color=always --icon=always'
elif exists tree; then
   TREE='tree -aFC'
else
   die 'requires tree(1) or lsd(1)'
fi
export TREE

BAT_ARGS='--style=plain --paging=never --color=always --theme=ansi'
if exists bat; then
   CAT="bat $BAT_ARGS"
elif exists batcat; then
   CAT="batcat $BAT_ARGS"
else
   CAT=cat
fi
export CAT


COLUMNS=$(stty size | cut -f2 -d' ')

#find -maxdepth 1 |
#sed -e 's:\./::' -e 's:^\.$::'
find ./* -prune 2>/dev/null                    |
sed 's:^\./::'                                 |
while IFS= read -r i; do
   if ! [ -d "$i" ]; then
      printf '\033[34m%s\033[m\n' "$i"
   elif is_installed "$i"; then
      printf '\033[33m%s\033[m\n' "$i"
   else
      printf '%s\n' "$i"
   fi
done                                           |
fzf --ansi                                     \
    --preview-window "right:$((COLUMNS - 22))" \
    --preview 'if [ -d {} ]
                  then $TREE {}
                  else $CAT  {}
               fi'                             \
    --query "$*"
