#!/bin/sh

# Usage: $0 [fzf_arguments]...
#        $0 [query...]
# a fzf TUI for tldr
#
# Tab: open the TLDR page in pager

# return 0 iff the arguments are valid arguments to fzf
is_fzf_args() { echo 'x' | fzf "$@" --filter='x' >/dev/null 2>/dev/null; }

is_fzf_args "$@" || set -- --query "$*"

{ echo
  tldr -l -p all |
  while IFS= read -r cmd; do
     if command -v "$cmd" > /dev/null
        then printf '\033[32m%s\033[0m\n' "$cmd"
        else printf '%s\n' "$cmd"
     fi
  done
}                                                 |
fzf --ansi                                        \
    --preview-label 'tldr'                        \
    --preview-window 'right:80%:wrap'             \
    --preview 'if [ -z {} ]
                  then tldr </dev/tty 2>&1
                  else tldr {}
               fi'                                \
    --bind 'tab:execute(tldr {} 2>&1 | less -MR)' \
    "$@"
