#!/bin/sh

# Usage: $0 [fzf_arguments]...
#        $0 [query]...
# (fzf-based) TUI Help Browser TUI for busybox

. ~/.local/lib/sh/common.sh
requires fzf

# return 0 iff the arguments are valid arguments to fzf
is_fzf_args() { echo 'x' | fzf "$@" --filter='x' >/dev/null 2>/dev/null; }


# Note: This program also supports toybox (depends on the program's name $0)
BUSYBOX=''
case $0 in
   *busybox*) BUSYBOX='busybox' ;;
    *toybox*) BUSYBOX='toybox'  ;;
           *) die 'only supports busybox or toybox' ;;
esac

PREVIEW="
   if [ -z {} ]; then
      case $BUSYBOX in
         busybox) busybox --help ;;
          toybox) toybox --version; echo
                  toybox; echo; echo
                  toybox --help;;
      esac 2>&1
   else
      $BUSYBOX --help {} 2>&1 | tail -n +3
   fi"

is_fzf_args "$@" || set -- --query "$*"

exists less && set -- --bind "tab:execute($PREVIEW | LESSOPEN='' less)" "$@"
exists man  && set -- --bind "alt-m:execute(man $BUSYBOX)" "$@"

COLUMNS=$(stty size </dev/tty | cut -f 2 -d ' ')
[ -n "$COLUMNS" ] || COLUMNS=80


case $BUSYBOX in
   # List the available applets
   busybox) busybox --list ;;
    toybox) toybox | tr ' ' '\n';;
esac                                                           |
while read -r applet; do
   # Display the applets with different colors based on
   # their availability as system commands
   [ -n "$applet" ] || continue
   cmd=$(poorman-which "$applet")
   if [ -z "$cmd" ]; then
      printf '\033[31m' # (not available as a command)
   elif realpath "$cmd" | grep -q $BUSYBOX; then
      printf '\033[32m' # (command links to busybox)
   else
      printf '\033[35m' # (command isn't a busybox applet)
   fi
   printf '\n%s\033[m' "$applet"
done                                                           |
fzf --preview-label  "$BUSYBOX"                                \
    --preview-window "right:$((COLUMNS - 20)),<60(bottom:66%)" \
    "$@"                                                       \
    --preview "if [ -z {} ]; then
                  printf '\033[33mColor legend (system commands vs $BUSYBOX applets)\n'
                  printf '\033[42m  \033[m system command is provided by $BUSYBOX\n'
                  printf '\033[41m  \033[m system provides a non-$BUSYBOX command\n'
                  printf '\033[45m  \033[m system does not provide this command\n'
                  printf '\033[34m_________________________________________________\033[m\n\n'
               fi
               $PREVIEW"
