#!/bin/sh

# Usage: $0 [OPTION] NAME
# Create a new shell script with the given name,
# Make it executable, and Launch it in editor
#
# By default, the script is created with a #!/bin/sh shebang,
# unless OPTION is used or alternatively the NAME ends with a
# specific extension.
#
# Options       Extension    Effect
# ----------------------------------------------------------
# -s, --sh                   forces a sh   shebang (default)
# -b, --bash    .bash        forces a bash shebang
# -z, --zsh     .zsh         forces a zsh  shebang
#
# editor is specified via environment variable VISUAL or
# alternatively EDITOR (or alternatively defaults to vi)


. ~/.local/lib/sh/common.sh

case $1 in


   -b|--bash) shift ; MODE='bash' ;;
    -z|--zsh) shift ; MODE='zsh'  ;;
     -s|--sh) shift ; MODE='sh'   ;;

       ''|-*) usage ;;

           *) # when no option is used:
              case $1 in
                 *.bash) MODE='bash' ;;
                  *.zsh) MODE='zsh'  ;;
                      *) MODE='sh'   ;;
              esac ;;
esac
[ $# -eq  1 ] || usage

# Create the file (if it already exists, it's ok, we can open it in the editor)
if ! [ -e "$1" ]; then
   { # Note: For max. portability, correct shebang for bash is
     #       #!/usr/bin/env bash and not #!/bin/bash
     case $MODE in
        bash) BANG='#!/usr/bin/env bash' ;;
         zsh) BANG='#!/usr/bin/env zsh'  ;;
          sh) BANG='#!/bin/sh' ;;
     esac

     #shellcheck disable=SC2016
     printf '%s\n\n# Usage: $0\n' "$BANG"
     cat << EOF
# 

# uncomment to include common shell functions
# . ~/.local/lib/sh/common.sh

EOF
   } >> "$1"

   chmod 755 "$1"
fi

${VISUAL:-${EDITOR:-vi}} "$1"
