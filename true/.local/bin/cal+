#!/bin/sh

# Usage: $0 [cal_arguments]... [[month] year]
# Display a calendar using the cal(1) program
#
# By default:
# * Use Monday as the first day of the week (not always possible)
# * When output is on a tty, try to highlight the current day (IF cal supports
#   it) and put some colors (IF cal can display Monday as the week day)
#
# Note: arguments accepted by cal depend on your version of cal(1)

. "$(etc-home)"/ncal/.local/bin/ncal+
