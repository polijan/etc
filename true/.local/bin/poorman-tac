#!/bin/sh

# Usage: $0 [FILE]...
# poorman's version of tac(1) (does not support options)
#
# Display and concatenate files with lines in reversed order
# With no FILE, or when FILE is -, read standard input.

 ~/.local/lib/sh/poorman.sh
poorman_try tac "$@"

if exists fzf; then
   # I find it fun to use fzf in this way :)
   cat "$@" | FZF_DEFAULT_OPTS='' fzf --filter '^' --tac --no-sort
else
   # slow: https://unix.stackexchange.com/questions/233014/how-does-the-command-sed-1ghd-reverse-the-contents-of-a-file
   sed '1!G;h;$!d' "$@"
fi
