#!/bin/sh

# Usage: ls+ [LS_ARGS]...
# my wrapper around ls

exists() { command -v "$@" > /dev/null; }

ls_() {
   LS='ls'

   # lsd is a "replacement" for ls with lots of added features
   # like colors, icons, tree-view, more formatting options etc.
   # https://github.com/lsd-rs/lsd
   if exists lsd && ! is-linux-console; then
      LS=lsd
      set -- --group-directories-first                 \
             --date +'%Y-%m-%d %H:%M'                  \
             "$@"

   # ls from GNU coreutils
   elif
      #shellcheck disable=SC2010
      ls --help 2>&1 | grep -qF 'dereference-command-line-symlink-to-dir'; then

      set -- --group-directories-first                 \
             --dereference-command-line-symlink-to-dir \
             --time-style=long-iso                     \
         "$@"
         ## --sort=extension
   fi

   # Assume ls understands `--color` (the options works also for busybox)
   "$LS" -h -F --color=auto "$@"
}


# We want "human" output collation
export LC_COLLATE='fr_FR.UTF-8'

# Particular case: if there's no argument and current directory is $HOME,
# we dont want to see all the dotfiles "junk"
if [ $# -eq 0 ] && [ "$PWD" = "$HOME" ]
   then ls_
   else ls_ -A "$@"
fi
