#!/bin/sh

# Usage: cpp-inspect [CPP_OPTIONS]... [HEADER-FILE]
# display typedefs, structs, unions and functions provided by a header file

show() {
   PAGER='less -FX'
   if exists bat; then
      bat -p -l cpp | $PAGER
   elif exists pygmentize; then
      pygmentize -l c++ | $PAGER
   else
      $PAGER
   fi
}

cpp "$@" | grep -v '^#' | grep -v '^$' | show
